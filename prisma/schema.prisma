datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  output        = "node_modules/@prisma/client"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

model User {
  id                      String                   @id @default(cuid())
  email                   String                   @unique
  passwordHash            String
  stripeCustomerId        String?                  @unique
  stripeSubscriptionId    String?
  stripeSubId             String?
  isPremium               Boolean                  @default(true)
  emailVerified           Boolean                  @default(false)
  premiumSince            DateTime?
  emailVerificationTokens EmailVerificationToken[]
  firstName               String? // neu
  lastName                String? // neu
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  watchlist               WatchlistItem[]
  passwordResetTokens     PasswordResetToken[]
  chartPresets            ChartPreset[]
  aiReportDownloads       AIReportDownload[]
}

model WatchlistItem {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  ticker    String
  createdAt DateTime @default(now())

  @@unique([userId, ticker])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  token     String   @unique
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

model ChartPreset {
  id        String    @id @default(cuid())
  user      User      @relation(fields: [userId], references: [id])
  userId    String
  name      String
  charts    String[] // Array of chart keys like ["revenue", "profit", "debt"]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  lastUsed  DateTime?

  @@index([userId])
  @@index([lastUsed])
}

model Subscriber {
  id           Int      @id @default(autoincrement())
  email        String
  investorSlug String
  createdAt    DateTime @default(now())

  @@unique([email, investorSlug])
}

// Earnings Calendar - cached from FMP API
model EarningsCalendar {
  id              String   @id @default(cuid())
  symbol          String
  companyName     String?
  date            DateTime
  time            String // 'bmo' (before market open), 'amc' (after market close), 'dmh' (during market hours)
  fiscalQuarter   Int? // 1, 2, 3, 4
  fiscalYear      Int?
  epsEstimate     Float?
  epsActual       Float?
  revenueEstimate Float?
  revenueActual   Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([symbol, date])
  @@index([date])
  @@index([symbol])
}

// Company-specific KPIs extracted from SEC EDGAR 8-K filings
// e.g. Netflix subscribers, Spotify MAUs, Uber trips, etc.
model CompanyKPI {
  id         String   @id @default(cuid())
  ticker     String
  metric     String
  label      String
  value      Float
  unit       String
  period     String
  periodDate DateTime
  source     String   @default("SEC EDGAR 8-K")
  filingUrl  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([ticker, metric, period])
  @@index([ticker])
  @@index([ticker, metric])
  @@index([periodDate])
}

// AI Report Downloads - tracks who downloads DCF reports
model AIReportDownload {
  id          String   @id @default(cuid())
  user        User     @relation(fields: [userId], references: [id])
  userId      String
  ticker      String
  companyName String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([ticker])
}

// ═══════════════════════════════════════════════════════════════════════════
// DAX 40 Financial Data – manuell gepflegte eigene Daten
// ═══════════════════════════════════════════════════════════════════════════

// DAX-Firma Metadaten (40 Einträge, selten geändert)
model DaxCompany {
  id               String    @id @default(cuid())
  ticker           String    @unique // z.B. "SAP.DE"
  tickerUS         String? // US ADR falls vorhanden (z.B. "SAP")
  isin             String?
  lei              String? // Legal Entity Identifier
  name             String
  nameShort        String? // "BMW" statt "Bayerische Motoren Werke Aktiengesellschaft"
  sector           String?
  industry         String?
  country          String    @default("DE")
  currency         String    @default("EUR")
  fiscalYearEnd    String    @default("12-31") // "MM-DD"
  irUrl            String? // IR-Startseite
  reportsUrl       String? // Seite wo die Quartalsberichte liegen
  nextEarningsDate DateTime? // nächstes erwartetes Berichtsdatum (für Reminder)
  lastReportedQ    String? // "Q3-2025" – letzter bekannter Bericht
  active           Boolean   @default(true) // aktuell im DAX?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  statements FinancialStatement[]

  @@index([ticker])
  @@index([nextEarningsDate])
}

// Finanzdaten pro Quartal/Jahr – manuell eingepflegt
model FinancialStatement {
  id           String     @id @default(cuid())
  company      DaxCompany @relation(fields: [ticker], references: [ticker], onDelete: Cascade)
  ticker       String
  fiscalYear   Int // 2024
  fiscalPeriod String // "Q1", "Q2", "Q3", "Q4", "FY", "H1", "9M"
  periodEnd    DateTime // letzter Tag des Berichtszeitraums
  reportDate   DateTime? // wann veröffentlicht
  currency     String     @default("EUR")

  // ── Income Statement (in Mio. – kompatibel mit FMP/SEC) ──
  revenue           Float?
  costOfRevenue     Float?
  grossProfit       Float?
  rAndD             Float?
  sgA               Float?
  operatingExpenses Float?
  operatingIncome   Float? // EBIT
  ebitda            Float?
  interestExpense   Float?
  incomeTax         Float?
  netIncome         Float?
  eps               Float? // basic
  epsDiluted        Float?
  sharesOutstanding Float? // in Mio.

  // ── Balance Sheet (Instant, Ende Periode) ──
  cashAndEquivalents Float?
  shortTermInvest    Float?
  inventory          Float?
  receivables        Float?
  totalCurrentAssets Float?
  ppE                Float? // Property, Plant & Equipment
  goodwill           Float?
  totalAssets        Float?
  shortTermDebt      Float?
  longTermDebt       Float?
  totalDebt          Float?
  totalLiabilities   Float?
  shareholdersEquity Float?

  // ── Cash Flow Statement ──
  operatingCashFlow Float?
  capex             Float?
  freeCashFlow      Float?
  dividendsPaid     Float?
  shareRepurchases  Float?

  // ── Meta ──
  sourceUrl      String? // Link zum Original-PDF/Bericht
  source         String   @default("manual") // "manual" | "esef-upload" | "esef-api"
  rawFacts       Json? // Alle extrahierten iXBRL Facts (auch unmapped). Key: "ifrs-full:Revenue@D-2024"
  notes          String? // Freitext für spezielle Fälle
  enteredByEmail String? // wer hat eingepflegt
  verified       Boolean  @default(false) // zweiter Check erfolgt
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([ticker, fiscalYear, fiscalPeriod])
  @@index([ticker])
  @@index([periodEnd])
  @@index([fiscalYear, fiscalPeriod])
}

// ═══════════════════════════════════════════════════════════════════════════
// Stock Splits – eigene cached Quelle (primär EODHD)
// Splits sind historisch immutable → DB-Cache vermeidet wiederholte API-Calls
// und ist Basis für eigene /api/v1/splits/{ticker} Veröffentlichung
// ═══════════════════════════════════════════════════════════════════════════

model StockSplit {
  id          String   @id @default(cuid())
  symbol      String // z.B. "NOW", "AAPL", "SAP.DE"
  splitDate   DateTime @db.Date // Ex-Date des Splits
  numerator   Int // z.B. 4 bei 4:1 Forward-Split
  denominator Int // z.B. 1 bei 4:1 (numerator < denominator = Reverse-Split)
  source      String   @default("eodhd") // "eodhd" | "fmp" | "manual"
  fetchedAt   DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([symbol, splitDate])
  @@index([symbol])
  @@index([splitDate])
}

// ═══════════════════════════════════════════════════════════════════════════
// IPO Calendar – eigene Daten direkt aus SEC EDGAR (Form 424B4 + S-1)
// 424B4 = finaler Pricing-Prospectus (Listing 1-2 Tage später)
// S-1   = Initial Registration (geplanter IPO, kein Pricing)
// S-1/A = Amendment zur Registration
// Befüllt vom wöchentlichen Cron /api/cron/sync-ipos
// ═══════════════════════════════════════════════════════════════════════════

model IpoCalendar {
  id          String   @id @default(cuid())
  cik         String // SEC Central Index Key (10-stellig, z.B. "0002102155")
  ticker      String? // optional, parsed aus display_names
  companyName String
  filingType  String // "424B4" | "S-1" | "S-1/A" | "EFFECT"
  filingDate  DateTime @db.Date // Datum des Filings (= IPO-Date für 424B4)
  accessionNo String   @unique // SEC Accession Number, z.B. "0001213900-26-051097"
  filingUrl   String // Link zum Filing-Index auf sec.gov
  status      String // "priced" (424B4) | "pending" (S-1, S-1/A) | "effective"
  sicCode     String? // SIC Industry Code
  bizState    String? // Geschäftssitz (z.B. "MA", "DE")
  bizLocation String? // Stadt/Land
  incState    String? // Incorporation State
  source      String   @default("sec-edgar")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([filingDate])
  @@index([status])
  @@index([ticker])
  @@index([cik])
}
